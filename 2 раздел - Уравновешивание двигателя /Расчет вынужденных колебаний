def calculate_A_iSigma(a_i, delta_i, k):
    """Расчет равнодействующего вектора амплитуд"""
    a_i_cylinders = a_i[:6] if len(a_i) >= 6 else a_i
    sum_sin = np.sum(a_i_cylinders * np.sin(k * delta_i))
    sum_cos = np.sum(a_i_cylinders * np.cos(k * delta_i))
    return np.sqrt(sum_sin**2 + sum_cos**2)

def calculate_Phi_k1(M_k_a, xi, omega_c, a_i, delta_i, k):
    """Расчет амплитуды первой моторной массы"""
    A_iSigma = calculate_A_iSigma(a_i, delta_i, k)
    a_i_cylinders = a_i[:6] if len(a_i) >= 6 else a_i
    sum_a_squared = np.sum(a_i_cylinders**2)
    
    if A_iSigma == 0:
        return 0
    return (M_k_a / (xi * omega_c)) * (sum_a_squared / A_iSigma)

def calculate_tau_max(M_j_a_upr, d_outer, d_inner=0):
    """Расчет касательного напряжения в МПа"""
    if d_inner == 0:
        W_p = (np.pi * d_outer**3) / 16
    else:
        W_p = (np.pi / 16) * ((d_outer**4 - d_inner**4) / d_outer)
    return M_j_a_upr / W_p / 1e6

