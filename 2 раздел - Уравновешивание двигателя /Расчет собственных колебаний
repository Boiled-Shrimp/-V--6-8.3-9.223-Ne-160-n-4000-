# Нахождение частот собственных колебаний
# Моменты инерции из таблицы
I_1 = 0.001149
I_2 = 0.0132
I_3 = 0.011
I_4 = 0.011
I_5 = 0.011
I_6 = 0.011
I_7 = 0.0132
I_8 = 0.306
I_9 = 0.0142867
I_10 = 0.008
I_11 = 0.00724
I_12 = 0.0195
I_13 = 0.457
I_14 = 23.74

# Коэффициенты жёсткости участков из таблицы
c_12 = 116.754 * 10**3
c_23 = 1030.67 * 10**3
c_34 = 915.531 * 10**3
c_45 = 1030.67 * 10**3
c_56 = 915.531 * 10**3
c_67 = 1030.67 * 10**3
c_78 = 756.473 * 10**3
c_89 = 19332.6 * 10**3
c_910 = 16.771 * 10**3
c_1011 = 35.81 * 10**3
c_1112 = 1.683 * 10**3
c_1213 = 13.207 * 10**3
c_1314 = 10.963 * 10**3

# Увеличиваем диапазон для поиска частот до 12000
omega_c = np.arange(0, 20000)  # От 0 до 12000
a_1 = 1
a_2 = a_1 - I_1 * a_1 * omega_c**2 / c_12
a_3 = a_2 - (I_1 * a_1 + I_2 * a_2) * omega_c**2 / c_23
a_4 = a_3 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3) * omega_c**2 / c_34
a_5 = a_4 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4) * omega_c**2 / c_45
a_6 = a_5 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5) * omega_c**2 / c_56
a_7 = a_6 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6) * omega_c**2 / c_67
a_8 = a_7 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7) * omega_c**2 / c_78
a_9 = a_8 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8) * omega_c**2 / c_89
a_10 = a_9 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8 + I_9 * a_9) * omega_c**2 / c_910
a_11 = a_10 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8 + I_9 * a_9 + I_10 * a_10) * omega_c**2 / c_1011
a_12 = a_11 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8 + I_9 * a_9 + I_10 * a_10 + I_11 * a_11) * omega_c**2 / c_1112
a_13 = a_12 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8 + I_9 * a_9 + I_10 * a_10 + I_11 * a_11 + I_12 * a_12) * omega_c**2 / c_1213
a_14 = a_13 - (I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8 + I_9 * a_9 + I_10 * a_10 + I_11 * a_11 + I_12 * a_12 + I_13 * a_13) * omega_c**2 / c_1314

# Если R(omega_c) = 0, то omega_c - собственная частота
R = I_1 * a_1 + I_2 * a_2 + I_3 * a_3 + I_4 * a_4 + I_5 * a_5 + I_6 * a_6 + I_7 * a_7 + I_8 * a_8 + I_9 * a_9 + I_10 * a_10 + I_11 * a_11 + I_12 * a_12 + I_13 * a_13 + I_14 * a_14

# Ищем все собственные частоты (для 14 масс может быть до 14 частот)
max_freq = 14  # Максимальное количество собственных частот
omega_a = np.zeros(max_freq)
j = 0
for i in range(1, len(omega_c)):  # Начинаем с 1, так как i-1 будет 0
    if R[i] <= 0 and R[i-1] >= 0:
        j = j + 1
        if j <= max_freq:  # Защита от выхода за границы массива
            omega_a[j-1] = i
    if R[i] >= 0 and R[i-1] <= 0:
        j = j + 1
        if j <= max_freq:  # Защита от выхода за границы массива
            omega_a[j-1] = i

# Обрезаем массив до фактического количества найденных частот
omega_a = omega_a[:j]

