# Создаем матрицу амплитуд для всех найденных частот
a_all = np.zeros((14, j))  # 14 масс x j частот

# Заполняем матрицу амплитуд
for freq_idx in range(j):
    idx = int(omega_a[freq_idx]) - 1  # Индексация в Python начинается с 0
    if idx < len(omega_c):  # Проверка на корректность индекса
        a_all[:, freq_idx] = [
            a_1, 
            a_2[idx], 
            a_3[idx], 
