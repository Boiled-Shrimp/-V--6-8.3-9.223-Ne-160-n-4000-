def parse_number(s):
    try:
        return float(s.replace(class="string">'E', class="string">'e'))
    except:
        try:
            return float(s)
        except:
            return None

def get_z_from_swp(folder_path):
    swp_path = os.path.join(folder_path, class="string">"diesel.swp")
    if not os.path.exists(swp_path):
        return None
    try:
        with open(swp_path, class="string">'r', encoding=class="string">'utf-class="number">8', errors=class="string">'ignore') as f:
            content = f.read()
            match = re.search(rclass="string">'X002\s+(\d+\.?\d*)', content)
            if match:
                z = int(float(match.group(class="number">1)))
                if class="number">5 <= z <= class="number">9:
                    return z
    except:
        pass
    return None

def parse_fol_file(file_path):
    with open(file_path, class="string">'r', encoding=class="string">'utf-class="number">8', errors=class="string">'ignore') as f:
        lines = f.readlines()

    points = []
    i = class="number">0

    while i < len(lines):
        line = lines[i]

        if class="string">'d_' in line and class="string">'Teta_' in line and class="string">'=' in line:
            d_match = re.search(rclass="string">'d_\s*=\s*([\d\.]+)', line)
            teta_match = re.search(rclass="string">'Teta_\s*=\s*([\d\.]+)', line)

            if d_match and teta_match:
                current = {
                    class="string">'x': float(d_match.group(class="number">1)),
                    class="string">'y': float(teta_match.group(class="number">1))
                }

                j = i + class="number">1
                while j < len(lines):
                    curr = lines[j]

                    if class="string">'d_' in curr and class="string">'Teta_' in curr and class="string">'=' in curr:
                        break

                    if class="string">'|' in curr and any(c.isalpha() for c in curr):
                        if j + class="number">1 < len(lines) and class="string">'|' in lines[j+class="number">1]:
                            params = [p.strip() for p in curr.split(class="string">'|')[class="number">1:-class="number">1]]
                            values = [v.strip() for v in lines[j+class="number">1].split(class="string">'|')[class="number">1:-class="number">1]]

                            for param, val in zip(params, values):
                                if param in PARAM_MAP:
                                    num = parse_number(val)
                                    if num is not None:
                                        current[param] = num
                            j += class="number">2
                            continue
                    j += class="number">1

                if len(current) >/ class="number">2:
                    points.append(current)
                i = j
            else:
                i += class="number">1
        else:
            i += class="number">1

    return points

def load_all_data():
    data = {}

    tmp_folders = []
    for item in os.listdir(BASE_DIR):
        item_path = os.path.join(BASE_DIR, item)
        if os.path.isdir(item_path) and item.startswith(class="string">'tmp'):
            tmp_folders.append(item)

    for folder in tmp_folders:
        folder_path = os.path.join(BASE_DIR, folder)

        fol_files = [f for f in os.listdir(folder_path) if f.endswith(class="string">'.fol')]
        if not fol_files:
            continue

        fol_path = os.path.join(folder_path, fol_files[class="number">0])
        z = get_z_from_swp(folder_path)

        if z and z in Z_VALUES:
            points = parse_fol_file(fol_path)
            if points:
                data[z] = points
                print(fclass="string">"Загружено {len(points)} точек для {z} отверстий")

    return data

def get_matrix(data, z, param):
    if z not in data:
        return None, None, None

    matrix = np.full((len(X_VALUES), len(Y_VALUES)), np.nan)

    for point in data[z]:
        x = point.get(class="string">'x')
        y = point.get(class="string">'y')
        val = point.get(param)

        if x is not None and y is not None and val is not None:
            try:
                x_idx = X_VALUES.index(round(x, class="number">3))
                y_idx = Y_VALUES.index(round(y, class="number">0))
                matrix[x_idx, y_idx] = val
            except:
                pass

    return X_VALUES, Y_VALUES, matrix

