                    ax.set_xlabel(AVAILABLE_PARAMS.get(self.current_y_code, self.current_y_code))
                    ax.set_ylabel(AVAILABLE_PARAMS.get(self.current_x_code, self.current_x_code))
                    ax.set_title(f'{title}\n{self.current_z_code}={z}')

                    valid = matrix[~np.isnan(matrix)]
                    if len(valid) > 0:
                        if param in ['be', 'NOx.,ppm', 'PM']:
                            opt = np.min(valid)
                        else:
                            opt = np.max(valid)
                        opt_idx = np.where(matrix == opt)
                        if len(opt_idx[0]) > 0:
                            ax.plot(Y[opt_idx[1][0]], X[opt_idx[0][0]], 'r*', markersize=15)
                            if opt < 1:
                                ax.annotate(f'{opt:.4f}', (Y[opt_idx[1][0]], X[opt_idx[0][0]]),
                                           xytext=(5, 5), textcoords='offset points', fontsize=9)
                            else:
                                ax.annotate(f'{opt:.1f}', (Y[opt_idx[1][0]], X[opt_idx[0][0]]),
                                           xytext=(5, 5), textcoords='offset points', fontsize=9)
                else:
                    ax.text(0.5, 0.5, 'Нет данных', transform=ax.transAxes, ha='center')
                    ax.set_xlabel(AVAILABLE_PARAMS.get(self.current_y_code, self.current_y_code))
                    ax.set_ylabel(AVAILABLE_PARAMS.get(self.current_x_code, self.current_x_code))

                param_idx += 1

            for idx in range(param_idx, 6):
                axes[idx].set_visible(False)

            plt.suptitle(f'Параметры двигателя - {self.current_z_code}={z}', fontsize=14)
            plt.tight_layout()
            plt.show()

        self.log("Отдельные графики построены")

    def plot_overlay(self):
        if not self.data:
            self.log("Нет данных!", error=True)
            return

        selected = [p for p, var in self.check_vars.items() if var.get() and p in self.available_params]

        if not selected:
            self.log("Выберите хотя бы один параметр", error=True)
            return

        self.log(f"Наложение параметров: {[DISPLAY_NAMES.get(p, p) for p in selected]}")

        z_list = sorted([z for z in self.current_z_values if z in self.data])

        for z in z_list:
            fig, ax = plt.subplots(figsize=(12, 10))

            for param in selected:
                X, Y, matrix = get_matrix(self.data, z, param, self.current_x_values, self.current_y_values)

                if matrix is not None and not np.all(np.isnan(matrix)):
                    matrix_disp = np.nan_to_num(matrix)
                    levels = 6
                    color = COLORS.get(param, 'black')
                    contour = ax.contour(Y, X, matrix_disp, levels=levels,
                                        colors=[color], linewidths=1.5, alpha=0.8)
                    ax.clabel(contour, inline=True, fontsize=8, fmt='%.2f')

            ax.set_xlabel(AVAILABLE_PARAMS.get(self.current_y_code, self.current_y_code), fontsize=12)
            ax.set_ylabel(AVAILABLE_PARAMS.get(self.current_x_code, self.current_x_code), fontsize=12)
            ax.set_title(f'Наложение изолиний - {self.current_z_code}={z}', fontsize=14)

            from matplotlib.patches import Patch
            legend_elements = [Patch(facecolor=COLORS.get(p, 'black'),
                                    label=DISPLAY_NAMES.get(p, p).split('[')[0].strip())
                              for p in selected]
            ax.legend(handles=legend_elements, loc='upper right', fontsize=10)
            ax.grid(True, alpha=0.3)
            plt.tight_layout()
            plt.show()

        self.log("Наложение изолиний построено")

    def save_json(self):
        if not self.data:
            self.log("Нет данных для сохранения", error=True)
            return

        output = {
            'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            'x_param': {'code': self.current_x_code, 'name': AVAILABLE_PARAMS.get(self.current_x_code, self.current_x_code), 'values': self.current_x_values},
            'y_param': {'code': self.current_y_code, 'name': AVAILABLE_PARAMS.get(self.current_y_code, self.current_y_code), 'values': self.current_y_values},
            'z_param': {'code': self.current_z_code, 'name': AVAILABLE_PARAMS.get(self.current_z_code, self.current_z_code), 'values': self.current_z_values},
            'data': {str(z): points for z, points in self.data.items()}
        }

        filename = f"optimizer_data_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        filepath = os.path.join(BASE_DIR, filename)

        with open(filepath, 'w', encoding='utf-8') as f:
            json.dump(output, f, indent=2, ensure_ascii=False)

        self.log(f"Данные сохранены: {filename}")

    def open_3d_optimizer(self):
        if not self.data:
            self.log("Сначала загрузите данные!", error=True)
            messagebox.showwarning("Нет данных", "Сначала загрузите данные (кнопка 'Загрузить данные')")
            return

        self.log("Открытие модуля 3D оптимизации...")

        opt_window = Toplevel(self.root)
        opt_window.title("3D Оптимизатор - Поиск по критериям")
        opt_window.geometry("1400x900")

        ThreeDOptimizer(opt_window, self.data, self.current_z_values, self.current_z_code)


class ThreeDOptimizer:
    def __init__(self, parent, data, z_values, z_code):
        self.parent = parent
        self.root = parent
        self.data = data
        self.z_values = z_values
        self.z_code = z_code

        self.create_widgets()
        self.log("3D оптимизатор готов. Задайте критерии и нажмите 'Поиск'")

    def create_widgets(self):
        main = ttk.Frame(self.root, padding="10")
        main.pack(fill='both', expand=True)

        top_frame = ttk.Frame(main)
        top_frame.pack(fill='x', pady=5)

        ttk.Button(top_frame, text="🔍 Поиск по критериям", command=self.open_criteria_window).pack(side='left', padx=5)
        ttk.Button(top_frame, text="📊 Построить график оптимумов", command=self.plot_optimization_graph).pack(side='left', padx=5)

        self.info = scrolledtext.ScrolledText(main, height=6)
        self.info.pack(fill='x', pady=5)

        self.info.delete(1.0, 'end')
        self.info.insert('end', "ЗАГРУЖЕННЫЕ ДАННЫЕ:\n")
        for z in self.z_values:
            if z in self.data:
                self.info.insert('end', f"  {self.z_code}={z}: {len(self.data[z])} точек\n")
            else:
                self.info.insert('end', f"  {self.z_code}={z}: нет данных\n")

        table_frame = ttk.LabelFrame(main, text="Результаты оптимизации (отсортированы по расходу топлива)")
        table_frame.pack(fill='both', expand=True, pady=5)

        columns = ('z', 'x', 'y', 'Ne', 'be', 'P_.max', 'Pz', 'NOx.,ppm', 'PM')
        self.tree = ttk.Treeview(table_frame, columns=columns, show='headings', height=12)

        self.tree.heading('z', text=self.z_code)
        self.tree.heading('x', text='Параметр X')
        self.tree.heading('y', text='Параметр Y')
        self.tree.heading('Ne', text='Мощность [кВт]')
        self.tree.heading('be', text='Расход [г/кВт·ч]')
        self.tree.heading('P_.max', text='P впрыска [бар]')
        self.tree.heading('Pz', text='P цикла [бар]')
        self.tree.heading('NOx.,ppm', text='NOx [ppm]')
        self.tree.heading('PM', text='PM [г/кВт·ч]')

        for col in columns:
            self.tree.column(col, width=100)

        scrollbar = ttk.Scrollbar(table_frame, orient=tk.VERTICAL, command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)

        self.tree.pack(side=tk.LEFT, fill='both', expand=True)
        scrollbar.pack(side=tk.RIGHT, fill='y')

        log_frame = ttk.LabelFrame(main, text="Лог")
        log_frame.pack(fill='x', pady=5)

        self.log_text = scrolledtext.ScrolledText(log_frame, height=8)
        self.log_text.pack(fill='both', expand=True, padx=5, pady=5)

    def log(self, msg, error=False):
        timestamp = datetime.now().strftime("%H:%M:%S")
        prefix = "❌" if error else "✓"
        self.log_text.insert('end', f"[{timestamp}] {prefix} {msg}\n")
        self.log_text.see('end')
        self.root.update()

    def open_criteria_window(self):
        criteria_win = Toplevel(self.root)
        criteria_win.title("Задание критериев отбора")
        criteria_win.geometry("600x500")
        criteria_win.transient(self.root)
        criteria_win.grab_set()

        ttk.Label(criteria_win, text="Задайте допустимые диапазоны для каждого параметра",
                  font=('Arial', 12)).pack(pady=10)

        frame = ttk.Frame(criteria_win, padding="10")
        frame.pack(fill='both', expand=True)

        entries = {}

        for i, (param, info) in enumerate(PARAM_CRITERIA.items()):
            row_frame = ttk.Frame(frame)
            row_frame.pack(fill='x', pady=5)

            ttk.Label(row_frame, text=info['name'], width=25).pack(side='left')

            min_entry = ttk.Entry(row_frame, width=10)
            min_entry.insert(0, str(info['min']))
            min_entry.pack(side='left', padx=5)
            ttk.Label(row_frame, text="до").pack(side='left')

            max_entry = ttk.Entry(row_frame, width=10)
            max_entry.insert(0, str(info['max']))
            max_entry.pack(side='left', padx=5)
            ttk.Label(row_frame, text=info['unit']).pack(side='left')

            entries[param] = (min_entry, max_entry)

        btn_frame = ttk.Frame(criteria_win)
        btn_frame.pack(pady=20)

        def apply_criteria():
            criteria = {}
            for param, (min_entry, max_entry) in entries.items():
                try:
                    min_val = float(min_entry.get())
                    max_val = float(max_entry.get())
                    criteria[param] = (min_val, max_val)
                except:
                    pass

            criteria_win.destroy()
            self.run_optimization(criteria)

        ttk.Button(btn_frame, text="🔍 Найти оптимальные варианты", command=apply_criteria).pack(side='left', padx=10)
        ttk.Button(btn_frame, text="Отмена", command=criteria_win.destroy).pack(side='left', padx=10)

    def run_optimization(self, criteria):
        self.log("Запуск оптимизации по заданным критериям...")

        all_points = []
        for z, points in self.data.items():
            for point in points:
                point_with_z = point.copy()
                point_with_z['z'] = z
                all_points.append(point_with_z)

        self.log(f"Всего точек для анализа: {len(all_points)}")

        valid_points = []
        for point in all_points:
            valid = True
            for param, (min_val, max_val) in criteria.items():
                if param in point:
                    val = point[param]
                    if val < min_val or val > max_val:
                        valid = False
                        break
                else:
                    valid = False
                    break

            if valid:
                valid_points.append(point)

        self.log(f"Найдено вариантов, удовлетворяющих критериям: {len(valid_points)}")

        if not valid_points:
            self.log("Нет вариантов, удовлетворяющих заданным критериям!", error=True)
            messagebox.showwarning("Нет результатов", "Нет вариантов, удовлетворяющих заданным критериям!\nРасширьте диапазоны параметров.")
            return

        valid_points.sort(key=lambda x: x.get('be', float('inf')))

        for item in self.tree.get_children():
            self.tree.delete(item)

        for point in valid_points:
            values = (
                point.get('z', '-'),
                f"{point.get('x', 0):.3f}",
                f"{point.get('y', 0):.1f}",
                f"{point.get('Ne', 0):.1f}",
                f"{point.get('be', 0):.2f}",
                f"{point.get('P_.max', 0):.0f}",
                f"{point.get('Pz', 0):.1f}",
                f"{point.get('NOx.,ppm', 0):.0f}",
                f"{point.get('PM', 0):.4f}"
            )
            self.tree.insert('', tk.END, values=values)

        self.log(f"Результаты выведены в таблицу. Наилучший расход: {valid_points[0].get('be', 0):.2f} г/кВт·ч")

        self.last_valid_points = valid_points
        self.last_criteria = criteria

        if messagebox.askyesno("График", "Построить график оптимальных областей?"):
            self.plot_optimization_graph()

    def plot_optimization_graph(self):
        if not hasattr(self, 'last_valid_points') or not self.last_valid_points:
            self.log("Нет данных для построения графика. Сначала выполните поиск!", error=True)
            return

        valid_points = self.last_valid_points

        fig = plt.figure(figsize=(16, 10))

        ax1 = fig.add_subplot(2, 2, 1)
        colors_list = ['blue', 'red', 'green', 'orange', 'purple']
        z_list = sorted(set(p['z'] for p in valid_points))

        for idx, z in enumerate(z_list):
            z_points = [p for p in valid_points if p['z'] == z]
            be_vals = [p['be'] for p in z_points]
            ne_vals = [p['Ne'] for p in z_points]
            ax1.scatter(be_vals, ne_vals, c=colors_list[idx % len(colors_list)], label=f'{self.z_code}={z}', s=50, alpha=0.7)

        ax1.set_xlabel('Расход топлива be [г/кВт·ч]')
        ax1.set_ylabel('Мощность Ne [кВт]')
        ax1.set_title('Зависимость мощности от расхода топлива')
        ax1.legend()
        ax1.grid(True, alpha=0.3)

        ax2 = fig.add_subplot(2, 2, 2)

        for idx, z in enumerate(z_list):
            z_points = [p for p in valid_points if p['z'] == z]
            be_vals = [p['be'] for p in z_points]
            nox_vals = [p.get('NOx.,ppm', 0) for p in z_points]
            ax2.scatter(be_vals, nox_vals, c=colors_list[idx % len(colors_list)], label=f'{self.z_code}={z}', s=50, alpha=0.7)

        ax2.set_xlabel('Расход топлива be [г/кВт·ч]')
        ax2.set_ylabel('Выбросы NOx [ppm]')
        ax2.set_title('Зависимость NOx от расхода топлива')
        ax2.legend()
        ax2.grid(True, alpha=0.3)

        ax3 = fig.add_subplot(2, 2, 3, projection='3d')

        for idx, z in enumerate(z_list):
            z_points = [p for p in valid_points if p['z'] == z]
            ne_vals = [p['Ne'] for p in z_points]
            be_vals = [p['be'] for p in z_points]
            nox_vals = [p.get('NOx.,ppm', 0) for p in z_points]
            ax3.scatter(ne_vals, be_vals, nox_vals, c=colors_list[idx % len(colors_list)], label=f'{self.z_code}={z}', s=50, alpha=0.7)

        ax3.set_xlabel('Мощность Ne [кВт]')
        ax3.set_ylabel('Расход be [г/кВт·ч]')
        ax3.set_zlabel('NOx [ppm]')
        ax3.set_title('3D зависимость параметров')
        ax3.legend()

        ax4 = fig.add_subplot(2, 2, 4)

        for idx, z in enumerate(z_list):
            z_points = [p for p in valid_points if p['z'] == z]
            p_inj_vals = [p.get('P_.max', 0) for p in z_points]
            pz_vals = [p.get('Pz', 0) for p in z_points]
            ax4.scatter(p_inj_vals, pz_vals, c=colors_list[idx % len(colors_list)], label=f'{self.z_code}={z}', s=50, alpha=0.7)

        ax4.set_xlabel('Давление впрыска P_впр [бар]')
        ax4.set_ylabel('Давление цикла Pz [бар]')
        ax4.set_title('Зависимость давлений')
        ax4.legend()
        ax4.grid(True, alpha=0.3)

        plt.suptitle('Оптимальные режимы работы двигателя', fontsize=16)
        plt.tight_layout()
        plt.show()
        self.log("Графики построены")


