# ========== ОБЩИЕ ФУНКЦИИ ==========
def parse_number(s):
    try:
        return float(s.replace('E', 'e'))
    except:
        try:
            return float(s)
        except:
            return None

def get_param_from_swp(folder_path, param_code):
    swp_path = os.path.join(folder_path, "diesel.swp")
    if not os.path.exists(swp_path):
        return None
    try:
        with open(swp_path, 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
            match = re.search(rf'{param_code}\s+([\d\.]+)', content)
            if match:
                return float(match.group(1))
    except:
        pass
    return None

def parse_fol_file(file_path, x_code, y_code):
    with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
        lines = f.readlines()

    points = []
    i = 0

    while i < len(lines):
        line = lines[i]

        if x_code in line and y_code in line and '=' in line:
            x_match = re.search(rf'{x_code}\s*=\s*([\d\.]+)', line)
            y_match = re.search(rf'{y_code}\s*=\s*([\d\.]+)', line)

            if x_match and y_match:
                current = {
                    'x': float(x_match.group(1)),
                    'y': float(y_match.group(1))
                }

                j = i + 1
                while j < len(lines):
                    curr = lines[j]

                    if x_code in curr and y_code in curr and '=' in curr:
                        break

                    if '|' in curr and any(c.isalpha() for c in curr):
                        if j + 1 < len(lines) and '|' in lines[j+1]:
                            params = [p.strip() for p in curr.split('|')[1:-1]]
                            values = [v.strip() for v in lines[j+1].split('|')[1:-1]]

                            for param, val in zip(params, values):
                                if param in PARAM_MAP:
                                    num = parse_number(val)
                                    if num is not None:
                                        current[param] = num
                            j += 2
                            continue
                    j += 1

                if len(current) > 2:
                    points.append(current)
                i = j
            else:
                i += 1
        else:
            i += 1

    return points

def load_all_data(x_code, y_code, z_code, x_values, y_values, z_values):
    data = {}

    tmp_folders = []
    for item in os.listdir(BASE_DIR):
        item_path = os.path.join(BASE_DIR, item)
        if os.path.isdir(item_path) and item.startswith('tmp'):
            tmp_folders.append(item)

    for folder in tmp_folders:
        folder_path = os.path.join(BASE_DIR, folder)

        fol_files = [f for f in os.listdir(folder_path) if f.endswith('.fol')]
        if not fol_files:
            continue

        fol_path = os.path.join(folder_path, fol_files[0])
        z = get_param_from_swp(folder_path, z_code)

        if z is not None and z in z_values:
            points = parse_fol_file(fol_path, x_code, y_code)
            if points:
                data[z] = points
                print(f"Загружено {len(points)} точек для {z_code}={z}")

    return data

def get_matrix(data, z, param, x_values, y_values):
    if z not in data:
        return None, None, None

    matrix = np.full((len(x_values), len(y_values)), np.nan)

    for point in data[z]:
        x = point.get('x')
        y = point.get('y')
        val = point.get(param)

        if x is not None and y is not None and val is not None:
            try:
                x_idx = x_values.index(round(x, 5))
                y_idx = y_values.index(round(y, 3))
                matrix[x_idx, y_idx] = val
            except ValueError:
                pass

    return x_values, y_values, matrix

