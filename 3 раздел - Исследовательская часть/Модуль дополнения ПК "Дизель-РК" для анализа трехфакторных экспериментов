class=class="string">"comment"># ========== 3D ОПТИМИЗАТОР (отдельный класс) ==========
class ThreeDOptimizer:
    def __init__(self, parent, data):
        self.parent = parent
        self.root = parent
        self.data = data

        self.create_widgets()
        self.log(class="string">"3D оптимизатор готов. Задайте критерии и нажмите 'Поиск'")

    def create_widgets(self):
        main = ttk.Frame(self.root, padding=class="string">"class="number">10")
        main.pack(fill=class="string">'both', expand=True)

        class=class="string">"comment"># Верхняя панель
        top_frame = ttk.Frame(main)
        top_frame.pack(fill=class="string">'x', pady=class="number">5)

        ttk.Button(top_frame, text=class="string">"🔍 Поиск по критериям", command=self.open_criteria_window).pack(side=class="string">'left', padx=class="number">5)
        ttk.Button(top_frame, text=class="string">"📊 Построить график оптимумов", command=self.plot_optimization_graph).pack(side=class="string">'left', padx=class="number">5)

        class=class="string">"comment"># Информация
        self.info = scrolledtext.ScrolledText(main, height=class="number">6)
        self.info.pack(fill=class="string">'x', pady=class="number">5)

        self.info.delete(class="number">1.0, class="string">'end')
        self.info.insert(class="string">'end', class="string">"ЗАГРУЖЕННЫЕ ДАННЫЕ:\n")
        for z in Z_VALUES:
            if z in self.data:
                self.info.insert(class="string">'end', fclass="string">"  {z} отверстий: {len(self.data[z])} точек\n")
            else:
                self.info.insert(class="string">'end', fclass="string">"  {z} отверстий: нет данных\n")

        class=class="string">"comment"># Таблица результатов
        table_frame = ttk.LabelFrame(main, text=class="string">"Результаты оптимизации (отсортированы по расходу топлива)")
        table_frame.pack(fill=class="string">'both', expand=True, pady=class="number">5)

        columns = (class="string">'z', class="string">'x', class="string">'y', class="string">'Ne', class="string">'be', class="string">'P_.max', class="string">'Pz', class="string">'NOx.,ppm', class="string">'PM')
        self.tree = ttk.Treeview(table_frame, columns=columns, show=class="string">'headings', height=class="number">12)

        self.tree.heading(class="string">'z', text=class="string">'Отверстий')
        self.tree.heading(class="string">'x', text=class="string">'Диаметр [мм]')
        self.tree.heading(class="string">'y', text=class="string">'Угол [°]')
        self.tree.heading(class="string">'Ne', text=class="string">'Мощность [кВт]')
        self.tree.heading(class="string">'be', text=class="string">'Расход [г/кВт·ч]')
        self.tree.heading(class="string">'P_.max', text=class="string">'P впрыска [бар]')
        self.tree.heading(class="string">'Pz', text=class="string">'P цикла [бар]')
        self.tree.heading(class="string">'NOx.,ppm', text=class="string">'NOx [ppm]')
        self.tree.heading(class="string">'PM', text=class="string">'PM [г/кВт·ч]')

        for col in columns:
            self.tree.column(col, width=class="number">100)

        scrollbar = ttk.Scrollbar(table_frame, orient=tk.VERTICAL, command=self.tree.yview)
        self.tree.configure(yscrollcommand=scrollbar.set)

        self.tree.pack(side=tk.LEFT, fill=class="string">'both', expand=True)
        scrollbar.pack(side=tk.RIGHT, fill=class="string">'y')

        class=class="string">"comment"># Лог
        log_frame = ttk.LabelFrame(main, text=class="string">"Лог")
        log_frame.pack(fill=class="string">'x', pady=class="number">5)

        self.log_text = scrolledtext.ScrolledText(log_frame, height=class="number">8)
        self.log_text.pack(fill=class="string">'both', expand=True, padx=class="number">5, pady=class="number">5)

    def log(self, msg, error=False):
        timestamp = datetime.now().strftime(class="string">"%H:%M:%S")
        prefix = class="string">"❌" if error else class="string">"✓"
        self.log_text.insert(class="string">'end', fclass="string">"[{timestamp}] {prefix} {msg}\n")
        self.log_text.see(class="string">'end')
        self.root.update()

    def open_criteria_window(self):
        criteria_win = Toplevel(self.root)
        criteria_win.title(class="string">"Задание критериев отбора")
        criteria_win.geometry(class="string">"600x500")
        criteria_win.transient(self.root)
        criteria_win.grab_set()

        ttk.Label(criteria_win, text=class="string">"Задайте допустимые диапазоны для каждого параметра",
                  font=(class="string">'Arial', class="number">12)).pack(pady=class="number">10)

        frame = ttk.Frame(criteria_win, padding=class="string">"class="number">10")
        frame.pack(fill=class="string">'both', expand=True)

        entries = {}

        for i, (param, info) in enumerate(PARAM_CRITERIA.items()):
            row_frame = ttk.Frame(frame)
            row_frame.pack(fill=class="string">'x', pady=class="number">5)

            ttk.Label(row_frame, text=info[class="string">'name'], width=class="number">25).pack(side=class="string">'left')

            min_entry = ttk.Entry(row_frame, width=class="number">10)
            min_entry.insert(class="number">0, str(info[class="string">'min']))
            min_entry.pack(side=class="string">'left', padx=class="number">5)
            ttk.Label(row_frame, text=class="string">"до").pack(side=class="string">'left')

            max_entry = ttk.Entry(row_frame, width=class="number">10)
            max_entry.insert(class="number">0, str(info[class="string">'max']))
            max_entry.pack(side=class="string">'left', padx=class="number">5)
            ttk.Label(row_frame, text=info[class="string">'unit']).pack(side=class="string">'left')

            entries[param] = (min_entry, max_entry)

        btn_frame = ttk.Frame(criteria_win)
        btn_frame.pack(pady=class="number">20)

        def apply_criteria():
            criteria = {}
            for param, (min_entry, max_entry) in entries.items():
                try:
                    min_val = float(min_entry.get())
                    max_val = float(max_entry.get())
                    criteria[param] = (min_val, max_val)
                except:
                    pass

            criteria_win.destroy()
            self.run_optimization(criteria)

        ttk.Button(btn_frame, text=class="string">"🔍 Найти оптимальные варианты", command=apply_criteria).pack(side=class="string">'left', padx=class="number">10)
        ttk.Button(btn_frame, text=class="string">"Отмена", command=criteria_win.destroy).pack(side=class="string">'left', padx=class="number">10)

    def run_optimization(self, criteria):
        self.log(class="string">"Запуск оптимизации по заданным критериям...")

        all_points = []
        for z, points in self.data.items():
            for point in points:
                point_with_z = point.copy()
                point_with_z[class="string">'z'] = z
                all_points.append(point_with_z)

        self.log(fclass="string">"Всего точек для анализа: {len(all_points)}")

        valid_points = []
        for point in all_points:
            valid = True
            for param, (min_val, max_val) in criteria.items():
                if param in point:
                    val = point[param]
                    if val < min_val or val >/ max_val:
                        valid = False
                        break
                else:
                    valid = False
                    break

            if valid:
                valid_points.append(point)

        self.log(fclass="string">"Найдено вариантов, удовлетворяющих критериям: {len(valid_points)}")

        if not valid_points:
            self.log(class="string">"Нет вариантов, удовлетворяющих заданным критериям!", error=True)
            messagebox.showwarning(class="string">"Нет результатов", class="string">"Нет вариантов, удовлетворяющих заданным критериям!\nРасширьте диапазоны параметров.")
            return

        valid_points.sort(key=lambda x: x.get(class="string">'be', float(class="string">'inf')))

        for item in self.tree.get_children():
            self.tree.delete(item)

        for point in valid_points:
            values = (
                point.get(class="string">'z', class="string">'-'),
                point.get(class="string">'x', class="string">'-'),
                point.get(class="string">'y', class="string">'-'),
                fclass="string">"{point.get('Ne', class="number">0):.1f}",
                fclass="string">"{point.get('be', class="number">0):.2f}",
                fclass="string">"{point.get('P_.max', class="number">0):.0f}",
                fclass="string">"{point.get('Pz', class="number">0):.1f}",
                fclass="string">"{point.get('NOx.,ppm', class="number">0):.0f}",
                fclass="string">"{point.get('PM', class="number">0):.4f}"
            )
            self.tree.insert(class="string">'', tk.END, values=values)

        self.log(fclass="string">"Результаты выведены в таблицу. Наилучший расход: {valid_points[class="number">0].get('be', class="number">0):.2f} г/кВт·ч")

        self.last_valid_points = valid_points
        self.last_criteria = criteria

        if messagebox.askyesno(class="string">"График", class="string">"Построить график оптимальных областей?"):
            self.plot_optimization_graph()

