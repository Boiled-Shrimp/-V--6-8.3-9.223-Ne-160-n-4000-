            self.current_x_code, self.current_y_code, self.current_z_code,
            self.current_x_values, self.current_y_values, self.current_z_values
        )

        if self.data:
            sample = list(self.data.values())[0][0]
            self.available_params = [p for p in PARAM_MAP.keys() if p in sample]
        else:
            self.available_params = []

        display_list = [DISPLAY_NAMES.get(p, p) for p in self.available_params]
        self.param_combo['values'] = display_list
        if display_list:
            self.param_combo.set(display_list[0])

        self.update_info()
        total_points = sum(len(p) for p in self.data.values())
        self.log(f"Загружено {len(self.data)} сканирований, всего {total_points} точек")
        self.log(f"Доступные параметры: {self.available_params}")

    def plot_single_param(self, event=None):
        if not self.data:
            self.log("Нет данных!", error=True)
            return

        selected = self.param_var.get()
        param = None
        for k, v in DISPLAY_NAMES.items():
            if v == selected:
                param = k
                break

        if not param or param not in self.available_params:
            self.log(f"Параметр {selected} не найден", error=True)
            return

        z_list = sorted([z for z in self.current_z_values if z in self.data])
        if not z_list:
            return

        self.log(f"Построение графика для: {DISPLAY_NAMES.get(param, param)}")

        n_z = len(z_list)
        n_cols = min(3, n_z)
        n_rows = (n_z + n_cols - 1) // n_cols
        fig, axes = plt.subplots(n_rows, n_cols, figsize=(5*n_cols, 4.5*n_rows))

        if n_z == 1:
            axes = [axes]
        else:
            axes = axes.flatten()

        for idx, z in enumerate(z_list):
            if idx >= len(axes):
                break
            ax = axes[idx]
            X, Y, matrix = get_matrix(self.data, z, param, self.current_x_values, self.current_y_values)

            if matrix is not None and not np.all(np.isnan(matrix)):
                matrix_disp = np.nan_to_num(matrix)
                cf = ax.contourf(Y, X, matrix_disp, levels=12, cmap='viridis')
                plt.colorbar(cf, ax=ax)

                contour = ax.contour(Y, X, matrix_disp, levels=6, colors='white', linewidths=0.8)
                ax.clabel(contour, inline=True, fontsize=8, fmt='%.3f')

                ax.set_xlabel(AVAILABLE_PARAMS.get(self.current_y_code, self.current_y_code))
                ax.set_ylabel(AVAILABLE_PARAMS.get(self.current_x_code, self.current_x_code))
                ax.set_title(f'{DISPLAY_NAMES.get(param, param)}\n{self.current_z_code}={z}')

                valid = matrix[~np.isnan(matrix)]
                if len(valid) > 0:
                    if param in ['be', 'NOx.,ppm', 'PM']:
                        opt = np.min(valid)
                    else:
                        opt = np.max(valid)
                    opt_idx = np.where(matrix == opt)
                    if len(opt_idx[0]) > 0:
                        ax.plot(Y[opt_idx[1][0]], X[opt_idx[0][0]], 'r*', markersize=15)
                        if opt < 1:
                            ax.annotate(f'{opt:.4f}', (Y[opt_idx[1][0]], X[opt_idx[0][0]]),
                                       xytext=(5, 5), textcoords='offset points', fontsize=9)
                        else:
                            ax.annotate(f'{opt:.1f}', (Y[opt_idx[1][0]], X[opt_idx[0][0]]),
                                       xytext=(5, 5), textcoords='offset points', fontsize=9)
            else:
                ax.text(0.5, 0.5, 'Нет данных', transform=ax.transAxes, ha='center')
                ax.set_xlabel(AVAILABLE_PARAMS.get(self.current_y_code, self.current_y_code))
                ax.set_ylabel(AVAILABLE_PARAMS.get(self.current_x_code, self.current_x_code))

        for idx in range(len(z_list), len(axes)):
            axes[idx].set_visible(False)

        plt.suptitle(DISPLAY_NAMES.get(param, param), fontsize=14)
        plt.tight_layout()
        plt.show()
        self.log("График построен")

